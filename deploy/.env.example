# ============================================================
# 今天吃啥 — 生产环境变量模板
# ============================================================
# 用法：cp deploy/.env.example deploy/.env
#       编辑 deploy/.env 填入真实值
#       不要提交 deploy/.env 到版本控制！
# ============================================================

# ---- Spring Boot 运行 Profile ----
SPRING_PROFILES_ACTIVE=prod

# ---- 微信小程序（生产必须填写真实值）----
WECHAT_APPID=
WECHAT_SECRET=
WECHAT_MOCK_ENABLED=false

# ---- JWT 签名密钥（至少 32 字节，推荐 64 字节随机字符串）----
# 生成方式：openssl rand -base64 48
JWT_SECRET=

# ---- 管理后台 Token（用于 X-Admin-Token 认证）----
# 生成方式：openssl rand -base64 24
ADMIN_TOKEN=

# ---- MySQL 连接（容器内部通信，DB_HOST 固定为 mysql 服务名）----
DB_HOST=mysql
DB_PORT=3306
DB_NAME=eat_what
DB_USER=eatwhat
DB_PASSWORD=
MYSQL_ROOT_PASSWORD=

# ---- HTTPS 证书路径（宿主机路径，挂载到 Nginx 容器）----
# 示例：./nginx/certs/fullchain.pem  ./nginx/certs/privkey.pem
# 使用 acme.sh 或 certbot 签发免费证书
# CERT_DIR=./nginx/certs
