/* pages/feedback/feedback.wxss */

.feedback-page {
  min-height: 100vh;
  background-color: #FFF8EA;
  padding: 0 32rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.form-section {
  margin-top: 32rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #06452F;
  display: block;
  margin-bottom: 14rpx;
}

/* ========== 反馈类型芯片 ========== */

.type-options {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.chip-touch {
  min-height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chip-touch:active {
  transform: scale(0.97);
}

.chip {
  padding: 0 20rpx;
  border-radius: 12rpx;
  background-color: #F4EFE6;
  font-size: 26rpx;
  color: #19382D;
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chip-active {
  background-color: #F24A0D;
  color: #fff;
}

/* ========== 星级评分 ========== */

.rating-section {
  display: flex;
  gap: 16rpx;
}

.star {
  font-size: 48rpx;
  color: #E8DFD0;
  transition: color 0.15s;
}

.star.star-active {
  color: #FFB000;
}

.star:active {
  transform: scale(0.97);
}

/* ========== 白色卡片 ========== */

.white-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  border: 1rpx solid #E8DFD0;
  padding: 24rpx;
}

/* ========== 文本域 ========== */

.feedback-textarea {
  width: 100%;
  min-height: 200rpx;
  border: 2rpx solid #E8DFD0;
  border-radius: 12rpx;
  background-color: #FFF8EA;
  padding: 20rpx;
  font-size: 28rpx;
  color: #19382D;
  box-sizing: border-box;
}

.feedback-textarea:focus {
  border-color: #06452F;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #7A7468;
  margin-top: 8rpx;
}

/* ========== 输入框 ========== */

.feedback-input {
  width: 100%;
  height: 72rpx;
  border: 2rpx solid #E8DFD0;
  border-radius: 12rpx;
  background-color: #FFF8EA;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #19382D;
  box-sizing: border-box;
}

.feedback-input:focus {
  border-color: #06452F;
}

/* ========== 错误提示 ========== */

.error-msg {
  background-color: #FFF0F0;
  border: 1rpx solid #E8DFD0;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #D94A3A;
}

/* ========== 提交按钮 ========== */

.submit-btn {
  width: 100%;
  margin-top: 40rpx;
  height: 96rpx;
  font-size: 34rpx;
}
