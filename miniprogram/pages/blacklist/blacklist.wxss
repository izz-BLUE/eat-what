/* pages/blacklist/blacklist.wxss */

.list-page {
  min-height: 100vh;
  background-color: #FFF8EA;
  padding: 24rpx 32rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.empty-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

/* 列表区域 */
.list-section {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx solid #E8DFD0;
}

.list-row {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #E8DFD0;
  min-height: 80rpx;
}

.list-row:last-child {
  border-bottom: none;
}

.list-row-content {
  flex: 1;
  min-width: 0;
}

.list-row-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #19382D;
  margin-bottom: 6rpx;
  word-break: break-all;
}

.list-row-category {
  font-size: 24rpx;
  color: #F24A0D;
  background-color: #FFF8EA;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  display: inline-block;
  margin-bottom: 4rpx;
}

.list-row-reason {
  font-size: 26rpx;
  color: #7A7468;
  word-break: break-all;
  margin-bottom: 4rpx;
}

.list-row-time {
  font-size: 24rpx;
  color: #7A7468;
}

/* 危险文字按钮 */
.btn-danger-text {
  font-size: 26rpx;
  color: #D94A3A;
  padding: 12rpx 16rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
  min-height: 80rpx;
  display: flex;
  align-items: center;
}

.btn-danger-text:active {
  transform: scale(0.97);
}
