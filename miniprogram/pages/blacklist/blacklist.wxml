<!--pages/blacklist/blacklist.wxml-->
<view class="list-page">
  <!-- 1. 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 2. 未登录 -->
  <view class="empty-state" wx:elif="{{notLoggedIn}}">
    <image class="empty-avatar brand-avatar-entrance" src="/assets/images/brand-avatar.png" mode="aspectFit" />
    <text>请先登录后查看黑名单</text>
    <button class="btn-primary" bindtap="goToLogin" style="margin-top: 32rpx;">去登录</button>
  </view>

  <!-- 3. 网络/业务错误 -->
  <view class="error-state" wx:elif="{{errorMsg}}">
    <text>{{errorMsg}}</text>
  </view>

  <!-- 4. 空列表 -->
  <view class="empty-state" wx:elif="{{items.length === 0}}">
    <image class="empty-avatar brand-avatar-entrance" src="/assets/images/brand-avatar.png" mode="aspectFit" />
    <text>黑名单还是空的</text>
  </view>

  <!-- 5. 正常列表 -->
  <block wx:else>
    <view class="list-section">
      <view class="list-row" wx:for="{{items}}" wx:key="id">
        <view class="list-row-content">
          <view class="list-row-name">{{item.foodName}}</view>
          <text class="list-row-category" wx:if="{{item.category}}">{{item.category}}</text>
          <view class="list-row-reason" wx:if="{{item.reason}}">原因：{{item.reason}}</view>
          <view class="list-row-time">{{item.createdAt}}</view>
        </view>
        <view class="btn-danger-text" bindtap="handleRemove" data-id="{{item.id}}" data-name="{{item.foodName}}">
          {{removing === item.id ? '移除中' : '移出'}}
        </view>
      </view>
    </view>
  </block>
</view>
