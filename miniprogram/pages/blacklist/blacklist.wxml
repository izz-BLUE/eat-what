<!--pages/blacklist/blacklist.wxml-->
<view class="container">
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <view class="empty-state" wx:elif="{{items.length === 0}}">
    <text>黑名单还是空的</text>
  </view>

  <view class="error-state" wx:elif="{{errorMsg}}">
    <text>{{errorMsg}}</text>
  </view>

  <block wx:else>
    <view class="blacklist-item" wx:for="{{items}}" wx:key="id">
      <view class="item-content">
        <view class="item-name">{{item.foodName}}</view>
        <text class="item-category" wx:if="{{item.category}}">{{item.category}}</text>
        <view class="item-reason" wx:if="{{item.reason}}">原因：{{item.reason}}</view>
        <view class="item-time">{{item.createdAt}}</view>
      </view>
      <button class="btn-remove" bindtap="handleRemove" data-id="{{item.id}}" data-name="{{item.foodName}}" disabled="{{removing === item.id}}">
        {{removing === item.id ? '移除中' : '移出'}}
      </button>
    </view>
  </block>
</view>
