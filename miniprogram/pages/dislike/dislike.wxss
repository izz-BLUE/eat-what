/* pages/dislike/dislike.wxss */

.dislike-page {
  min-height: 100vh;
  background-color: #FFF8EA;
  padding: 24rpx 32rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.empty-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

/* 添加区块 */
.dislike-add-block {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx 28rpx 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #E8DFD0;
}

.dislike-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #06452F;
  margin-bottom: 14rpx;
  display: block;
}

.dislike-options {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 24rpx;
}

/* 芯片触摸容器（透明，80rpx 可点击区域） */
.dislike-chip-touch {
  min-height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dislike-chip-touch:active {
  transform: scale(0.97);
}

/* 芯片视觉（与首页统一：72rpx） */
.dislike-chip {
  padding: 0 18rpx;
  border-radius: 12rpx;
  background-color: #F4EFE6;
  font-size: 26rpx;
  color: #19382D;
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dislike-chip.chip-active {
  background-color: #F24A0D;
  color: #fff;
}

/* 分隔标题 */
.dislike-divider {
  padding: 8rpx 0 20rpx;
}

.divider-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #06452F;
}

/* 列表区域 */
.list-section {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx solid #E8DFD0;
}

.list-row {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #E8DFD0;
  min-height: 80rpx;
}

.list-row:last-child {
  border-bottom: none;
}

.list-row-content {
  flex: 1;
  min-width: 0;
}

.list-row-cat {
  font-size: 32rpx;
  font-weight: 600;
  color: #19382D;
  display: block;
  word-break: break-all;
}

.list-row-expire {
  font-size: 24rpx;
  color: #7A7468;
  margin-top: 6rpx;
  display: block;
}

/* 危险文字按钮 */
.btn-danger-text {
  font-size: 26rpx;
  color: #D94A3A;
  padding: 12rpx 16rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
  min-height: 80rpx;
  display: flex;
  align-items: center;
}

.btn-danger-text:active {
  transform: scale(0.97);
}
