/* pages/dislike/dislike.wxss */

.section-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
}

.add-section {
  margin-bottom: 32rpx;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.cat-option {
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
  font-size: 26rpx;
  color: #666;
}

.cat-option.active {
  background: #FF6B35;
  color: #fff;
}

.dislike-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-info {
  flex: 1;
}

.item-cat {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  display: block;
}

.item-expire {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.btn-remove {
  font-size: 26rpx;
  color: #ff4d4f;
  background: #fff;
  border: 1rpx solid #ff4d4f;
  border-radius: 8rpx;
  padding: 8rpx 24rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}
