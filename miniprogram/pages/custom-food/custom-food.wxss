/* pages/custom-food/custom-food.wxss */

.custom-food-page {
  min-height: 100vh;
  background-color: #FFF8EA;
  padding: 24rpx 32rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

/* ========== 空状态 ========== */

.empty-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #7A7468;
}

/* ========== 表单卡片 ========== */

.add-block {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx 28rpx 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #E8DFD0;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #06452F;
  margin-bottom: 14rpx;
  display: block;
  margin-top: 20rpx;
}
.section-title:first-of-type {
  margin-top: 0;
}

.required-mark {
  color: #D94A3A;
  font-weight: 700;
}

/* 文本输入 */
.form-input {
  width: 100%;
  height: 76rpx;
  line-height: 76rpx;
  padding: 0 24rpx;
  border: 2rpx solid #E8DFD0;
  border-radius: 12rpx;
  font-size: 28rpx;
  background-color: #FFF8EA;
  box-sizing: border-box;
  margin-bottom: 4rpx;
}
.form-input.input-error {
  border-color: #D94A3A;
}

/* 错误提示 */
.form-error {
  font-size: 24rpx;
  color: #D94A3A;
  display: block;
  margin-bottom: 4rpx;
}

/* ========== Tag 选择 ========== */

.chip-options {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 8rpx;
}

.chip-touch {
  min-height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.chip-touch:active {
  transform: scale(0.97);
}

.chip {
  padding: 0 18rpx;
  border-radius: 12rpx;
  background-color: #F4EFE6;
  font-size: 26rpx;
  color: #19382D;
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.chip.chip-active {
  background-color: #F24A0D;
  color: #fff;
}

/* 提交按钮 */
.btn-submit {
  width: 100%;
  margin-top: 28rpx;
}

/* ========== 分隔线 ========== */

.divider {
  padding: 8rpx 0 20rpx;
}
.divider-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #06452F;
}

/* ========== 列表 ========== */

.list-section {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx solid #E8DFD0;
}

.list-row {
  display: flex;
  align-items: flex-start;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #E8DFD0;
  min-height: 80rpx;
}
.list-row:last-child {
  border-bottom: none;
}

.list-row-content {
  flex: 1;
  min-width: 0;
}

.list-row-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #19382D;
  display: block;
  word-break: break-all;
}

.list-row-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.tag-meal {
  background-color: #FFF8EA;
  color: #06452F;
  border: 1rpx solid #E8DFD0;
}
.tag-taste {
  background-color: #F4EFE6;
  color: #19382D;
}
.tag-price {
  background-color: #FFF8EA;
  color: #7A7468;
  border: 1rpx solid #E8DFD0;
}

.list-row-cats {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 6rpx;
}

.cat-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background-color: #F4EFE6;
  color: #19382D;
}

.list-row-time {
  font-size: 22rpx;
  color: #7A7468;
  display: block;
  margin-top: 6rpx;
}

/* ========== 删除按钮 ========== */

.btn-danger-text {
  font-size: 26rpx;
  color: #D94A3A;
  padding: 12rpx 16rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
  min-height: 80rpx;
  display: flex;
  align-items: center;
}
.btn-danger-text:active {
  transform: scale(0.97);
}

/* ========== 加载/错误/空状态 ========== */

.loading {
  text-align: center;
  padding: 80rpx 0;
  font-size: 28rpx;
  color: #7A7468;
}

.error-state {
  text-align: center;
  padding: 80rpx 0;
  font-size: 28rpx;
  color: #D94A3A;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

/* 复用全局 brand-avatar-entrance */
.brand-avatar-entrance {
  width: 140rpx;
  height: 140rpx;
  border-radius: 24rpx;
}
