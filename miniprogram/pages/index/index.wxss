/* pages/index/index.wxss */

.container {
  padding: 32rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.title-section {
  text-align: center;
  padding: 48rpx 0 32rpx;
  position: relative;
}

.profile-link {
  position: absolute;
  right: 0;
  top: 48rpx;
  font-size: 28rpx;
  color: #FF6B35;
}

.title {
  font-size: 56rpx;
  font-weight: 700;
  color: #FF6B35;
  display: block;
}

.subtitle {
  font-size: 28rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.filter-section {
  margin-bottom: 0;
}

.reset-section {
  text-align: right;
  margin-bottom: 32rpx;
}

.reset-link {
  font-size: 24rpx;
  color: #bbb;
  padding: 8rpx 16rpx;
}

.filter-group {
  margin-bottom: 24rpx;
}

.filter-group:last-child {
  margin-bottom: 0;
}

.filter-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-option {
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  background-color: #f5f5f5;
  font-size: 26rpx;
  color: #666;
  transition: all 0.2s;
}

.filter-option.active {
  background-color: #FF6B35;
  color: #fff;
}

.filter-option.disabled {
  background-color: #e0e0e0;
  color: #bbb;
}

.more-btn {
  color: #FF6B35;
  border: 1rpx dashed #FF6B35;
  background-color: transparent;
}

.more-btn.expanded {
  background-color: #FFF3E8;
  border-style: solid;
}

.more-categories {
  margin-top: 16rpx;
  padding: 16rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
}

.result-section {
  margin-top: 32rpx;
}

.result-card {
  text-align: center;
}

.food-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.food-info {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.food-category {
  font-size: 28rpx;
  color: #FF6B35;
  background-color: #FFF3E8;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.food-tags {
  font-size: 28rpx;
  color: #666;
  background-color: #f5f5f5;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.food-price {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.food-price-note {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 24rpx;
}

.reasons {
  background-color: #f9f9f9;
  padding: 24rpx;
  border-radius: 12rpx;
  text-align: left;
}

.reason-label {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.reason-item {
  font-size: 28rpx;
  color: #333;
  display: block;
  line-height: 1.6;
}

.main-button-section {
  margin-top: 64rpx;
  text-align: center;
}

.btn-large {
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  font-size: 40rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

/* 固定底部操作栏 */
.bottom-action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #fff;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

.action-buttons {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  flex: 1;
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.blacklist-action {
  margin-top: 16rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999;
}

/* 已决定状态 */
.decision-card {
  text-align: center;
}

.decision-badge {
  display: inline-block;
  background-color: #4CAF50;
  color: #fff;
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
}

.decision-time {
  font-size: 24rpx;
  color: #bbb;
  margin-top: 16rpx;
}
