/* pages/index/index.wxss */

/* ========== 页面容器 ========== */

.page-container {
  padding: 0 32rpx;
  /* bar-top(20) + btn-min-h(96) + bar-bot(20) + safe-area + extra(24) = 160 + safe, +24 safety */
  padding-bottom: calc(184rpx + env(safe-area-inset-bottom));
}

/* 结果锚点（零高度，仅作为滚动目标） */
.result-anchor {
  height: 0;
  overflow: hidden;
}

/* ========== 顶部品牌区（精简） ========== */

.brand-header {
  display: flex;
  align-items: center;
  padding: 16rpx 0 16rpx;
}

.brand-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.brand-center {
  flex: 1;
  min-width: 0;
}

.brand-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #06452F;
  display: block;
}

.brand-subtitle {
  font-size: 24rpx;
  color: #7A7468;
  display: block;
  margin-top: 2rpx;
}

.profile-entry {
  font-size: 26rpx;
  color: #06452F;
  flex-shrink: 0;
  margin-left: 16rpx;
  padding: 0 22rpx;
  height: 52rpx;
  line-height: 52rpx;
  border: 2rpx solid #06452F;
  border-radius: 999rpx;
  background-color: #FFFFFF;
  font-weight: 600;
}

/* ========== 筛选面板 ========== */

.filter-panel {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx 24rpx 16rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #E8DFD0;
}

/* 折叠切换头 */
.filter-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0 16rpx;
}

.filter-header-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #06452F;
}

.filter-header-action {
  font-size: 24rpx;
  color: #06452F;
  padding: 0 18rpx;
  border: 1rpx solid #E8DFD0;
  border-radius: 999rpx;
  background-color: #FFFFFF;
  height: 48rpx;
  line-height: 48rpx;
}

.filter-header:active .filter-header-action {
  background-color: #F4EFE6;
  border-color: #A8B8A0;
}

/* 折叠摘要 */
.filter-summary {
  font-size: 24rpx;
  color: #7A7468;
  line-height: 1.6;
  padding-bottom: 8rpx;
}

.filter-group {
  margin-bottom: 16rpx;
}

.filter-group:last-of-type {
  margin-bottom: 8rpx;
}

.filter-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #06452F;
  margin-bottom: 10rpx;
  display: block;
}

.filter-hint {
  font-size: 22rpx;
  color: #7A7468;
  display: block;
  margin-top: 8rpx;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

/* 芯片触摸容器（透明，80rpx 可点击区域） */
.filter-chip-touch {
  min-height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.filter-chip-touch:active {
  transform: scale(0.97);
}

/* 芯片视觉（72rpx） */
.filter-chip {
  padding: 0 18rpx;
  border-radius: 12rpx;
  background-color: #F4EFE6;
  font-size: 26rpx;
  color: #19382D;
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.filter-chip.chip-active {
  background-color: #F24A0D;
  color: #fff;
}

.filter-chip.disabled {
  background-color: #e0e0e0;
  color: #bbb;
}

/* 重置按钮 */
.filter-reset-row {
  text-align: right;
}

.reset-link {
  font-size: 24rpx;
  color: #06452F;
  padding: 12rpx 8rpx;
  min-height: 48rpx;
  font-weight: 500;
  text-decoration: underline;
  text-underline-offset: 4rpx;
}

/* ========== 推荐结果 / 已决定 ========== */

.result-area {
  margin-bottom: 16rpx;
}

.result-block {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx 28rpx;
  border: 1rpx solid #E8DFD0;
}

.result-food-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #06452F;
  margin-bottom: 14rpx;
  word-break: break-all;
}

.result-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.result-tag {
  font-size: 24rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.result-tag-type {
  background-color: #F4EFE6;
  color: #19382D;
}

.result-tag-cuisine {
  background-color: #F4EFE6;
  color: #19382D;
}

.result-tag-taste {
  background-color: #FFF8EA;
  color: #7A7468;
  border: 1rpx solid #E8DFD0;
}

.result-tags-taste {
  margin-top: 0rpx;
}

.result-price {
  font-size: 28rpx;
  color: #19382D;
  margin-bottom: 4rpx;
}

.result-price-note {
  font-size: 22rpx;
  color: #7A7468;
  margin-bottom: 20rpx;
}

.result-reasons {
  background-color: #FFF8EA;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
}

.result-reason-label {
  font-size: 24rpx;
  color: #06452F;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.result-reason-item {
  font-size: 26rpx;
  color: #19382D;
  display: block;
  line-height: 1.7;
}

/* ========== 已决定状态 ========== */

.decision-block {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx 28rpx;
  border: 1rpx solid #E8DFD0;
  text-align: center;
}

.decision-status {
  display: inline-block;
  background-color: #06452F;
  color: #fff;
  font-size: 24rpx;
  padding: 6rpx 24rpx;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
}

.decision-food-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #06452F;
  margin-bottom: 10rpx;
  word-break: break-all;
}

.decision-block .result-tags {
  justify-content: center;
  margin-bottom: 12rpx;
}

.decision-time {
  font-size: 24rpx;
  color: #7A7468;
  margin-top: 8rpx;
}

/* ========== 换一个已耗尽空状态 ========== */

.exhausted-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 40rpx 32rpx 36rpx;
  border: 1rpx solid #E8DFD0;
  text-align: center;
  margin-bottom: 16rpx;
  margin-top: 0rpx;
}

.exhausted-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #19382D;
  margin-bottom: 10rpx;
}

.exhausted-desc {
  display: block;
  font-size: 26rpx;
  color: #7A7468;
  line-height: 1.5;
}

/* ========== 统一固定底部操作栏 ========== */

.bottom-action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #FFFFFF;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #E8DFD0;
  z-index: 100;
}

.action-buttons {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  flex: 1;
  min-width: 0;
  white-space: nowrap;
  font-size: 26rpx;
  padding: 12rpx 24rpx;
}

.action-btn-left {
  flex: 0 0 42%;
}

.action-btn-right {
  flex: 0 0 58%;
}

.btn-single-action {
  width: 100%;
  height: 96rpx;
  font-size: 34rpx;
}

.dislike-action {
  margin-top: 14rpx;
  text-align: center;
  font-size: 24rpx;
  color: #7A7468;
  padding: 12rpx 0;
}

.dislike-disabled {
  color: #C4BEB6;
}

.blacklist-action {
  margin-top: 10rpx;
  text-align: center;
  font-size: 24rpx;
  color: #7A7468;
  padding: 12rpx 0;
}

/* ========== 自定义菜品入口 ========== */

.custom-food-entry {
  text-align: center;
  margin-bottom: 4rpx;
  min-height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.custom-food-entry text {
  display: inline-block;
  font-size: 24rpx;
  color: #06452F;
  font-weight: 500;
  padding: 0 24rpx;
  height: 56rpx;
  line-height: 56rpx;
  background-color: #FFF8EA;
  border: 1rpx solid #E8DFD0;
  border-radius: 999rpx;
}

.custom-food-entry:active {
  transform: scale(0.97);
}

/* ========== 自定义标签徽章 ========== */

.custom-badge {
  display: inline-block;
  font-size: 20rpx;
  color: #F24A0D;
  border: 2rpx solid #F24A0D;
  border-radius: 8rpx;
  padding: 2rpx 10rpx;
  margin-left: 12rpx;
  vertical-align: middle;
  font-weight: 500;
}
