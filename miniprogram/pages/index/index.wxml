<!--pages/index/index.wxml-->
<view class="container">
  <!-- 标题 -->
  <view class="title-section">
    <text class="title">今天吃啥</text>
    <text class="subtitle">帮你决定吃什么</text>
    <text class="profile-link" bindtap="goToProfile">我的 ›</text>
  </view>

  <!-- 筛选条件 -->
  <view class="filter-section card">
    <!-- 餐段 -->
    <view class="filter-group">
      <text class="filter-label">餐段</text>
      <view class="filter-options">
        <view
          wx:for="{{mealTypes}}"
          wx:key="value"
          class="filter-option {{item.selected ? 'active' : ''}}"
          bindtap="selectMealType"
          data-value="{{item.value}}"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <!-- 预算偏好 -->
    <view class="filter-group">
      <text class="filter-label">参考价位</text>
      <view class="filter-options">
        <view
          class="filter-option {{priceNoLimitSelected ? 'active' : ''}}"
          bindtap="selectPriceLevel"
          data-value=""
        >
          不限
        </view>
        <view
          wx:for="{{priceLevels}}"
          wx:key="value"
          class="filter-option {{item.selected ? 'active' : ''}}"
          bindtap="selectPriceLevel"
          data-value="{{item.value}}"
        >
          {{item.label}}
        </view>
      </view>
      <text class="filter-hint">实际价格因门店、份量和用餐方式而异</text>
    </view>

    <!-- 口味 -->
    <view class="filter-group">
      <text class="filter-label">口味</text>
      <view class="filter-options">
        <view
          class="filter-option {{tasteNoLimitSelected ? 'active' : ''}}"
          bindtap="selectTaste"
          data-value=""
        >
          不限
        </view>
        <view
          wx:for="{{tastes}}"
          wx:key="value"
          class="filter-option {{item.selected ? 'active' : ''}}"
          bindtap="selectTaste"
          data-value="{{item.value}}"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <!-- 食物类型（多选，与菜系合计最多3） -->
    <view class="filter-group">
      <text class="filter-label">食物类型（可选）</text>
      <view class="filter-options">
        <view
          class="filter-option {{categoryNoLimitSelected ? 'active' : ''}}"
          bindtap="selectCategoryNoLimit"
        >
          不限
        </view>
        <view
          wx:for="{{typeTagOptions}}"
          wx:key="value"
          class="filter-option {{item.selected ? 'active' : ''}}"
          bindtap="selectTypeTag"
          data-value="{{item.value}}"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <!-- 菜系/风格（多选，与食物类型合计最多3） -->
    <view class="filter-group">
      <text class="filter-label">菜系/风格（可选）</text>
      <view class="filter-options">
        <view
          wx:for="{{cuisineTagOptions}}"
          wx:key="value"
          class="filter-option {{item.selected ? 'active' : ''}}"
          bindtap="selectCuisineTag"
          data-value="{{item.value}}"
        >
          {{item.label}}
        </view>
      </view>
    </view>
  </view>

  <!-- 重置筛选 -->
  <view class="reset-section">
    <text class="reset-link" bindtap="handleReset">重置筛选条件</text>
  </view>

  <!-- 已决定状态 -->
  <view class="result-section" wx:if="{{mealDecision}}">
    <view class="card decision-card">
      <view class="decision-badge">今天就吃</view>
      <view class="food-name">{{mealDecision.foodName}}</view>
      <view class="food-info">
        <text class="food-category">{{mealDecision.category}}</text>
      </view>
      <view class="decision-time">决定时间：{{decisionTimeDisplay}}</view>
    </view>
  </view>

  <!-- 推荐结果（无决定时） -->
  <view class="result-section" wx:elif="{{recommendResult}}">
    <view class="card result-card">
      <view class="food-name">{{recommendResult.food.name}}</view>
      <view class="food-info">
        <text class="food-category">{{recommendResult.food.category}}</text>
        <text class="food-tags" wx:if="{{recommendResult.food.tasteTags}}">{{recommendResult.food.tasteTags}}</text>
      </view>
      <view class="food-price">
        参考价位：{{priceDisplay}}
      </view>
      <view class="food-price-note">具体价格因门店、份量和用餐方式而异</view>
      <view class="reasons" wx:if="{{recommendResult.reasons.length > 0}}">
        <text class="reason-label">推荐理由：</text>
        <text wx:for="{{recommendResult.reasons}}" wx:key="*this" class="reason-item">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 主按钮（无决定、无推荐时显示） -->
  <view class="main-button-section" wx:if="{{!mealDecision && !recommendResult}}">
    <button class="btn-primary btn-large" bindtap="getRecommend" disabled="{{loading}}">
      {{loading ? '推荐中...' : '今天吃啥'}}
    </button>
  </view>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading && !recommendResult && !mealDecision}}">
    <text>正在为你推荐...</text>
  </view>

  <!-- 错误状态 -->
  <view class="error-state" wx:if="{{errorMsg}}">
    <text>{{errorMsg}}</text>
    <button class="btn-secondary" bindtap="getRecommend" style="margin-top: 24rpx;">重试</button>
  </view>
</view>

<!-- 固定底部操作栏：已决定 -->
<view class="bottom-action-bar" wx:if="{{mealDecision}}">
  <view class="action-buttons">
    <button class="btn-secondary action-btn" bindtap="handleReselect">重新选择</button>
    <button class="btn-primary action-btn" bindtap="handleFinishEating">吃完了，记录一下</button>
  </view>
</view>

<!-- 固定底部操作栏：推荐结果 -->
<view class="bottom-action-bar" wx:elif="{{recommendResult}}">
  <view class="action-buttons">
    <button class="btn-secondary action-btn" bindtap="swapRecommend" disabled="{{swapCount >= maxSwapCount || loading}}">
      换一个{{swapCount > 0 ? '(' + swapCount + '/' + maxSwapCount + ')' : ''}}
    </button>
    <button class="btn-primary action-btn" bindtap="eatIt" disabled="{{loading}}">
      我就吃它
    </button>
  </view>
  <view class="blacklist-action" bindtap="addToBlacklist">
    <text>加入黑名单</text>
  </view>
</view>
