<!--pages/index/index.wxml-->
<wxs module="tag">
  module.exports = {
    /**
     * 将逗号分隔字符串拆分为数组，用于标签展示。
     * 示例："辣,麻,香" → ["辣","麻","香"]
     */
    split: function(str) {
      if (!str) return [];
      var parts = str.split(',');
      var result = [];
      for (var i = 0; i < parts.length; i++) {
        var s = parts[i].trim();
        if (s) result.push(s);
      }
      return result;
    }
  }
</wxs>
<view class="page-container">
  <!-- 顶部品牌区（精简） -->
  <view class="brand-header">
    <image class="brand-avatar brand-avatar-entrance" src="/assets/images/brand-avatar.png" mode="aspectFit" />
    <view class="brand-center">
      <text class="brand-title">今天想吃什么？</text>
      <text class="brand-subtitle">挑好条件，我来选</text>
    </view>
    <text class="profile-entry" bindtap="goToProfile">我的</text>
  </view>

  <!-- 筛选条件面板 -->
  <view class="filter-panel">
    <!-- 餐段 -->
    <view class="filter-group">
      <text class="filter-label">餐段</text>
      <view class="filter-options">
        <view
          wx:for="{{mealTypes}}"
          wx:key="value"
          class="filter-chip-touch"
          bindtap="selectMealType"
          data-value="{{item.value}}"
        >
          <view class="filter-chip {{item.selected ? 'chip-active' : ''}}">{{item.label}}</view>
        </view>
      </view>
    </view>

    <!-- 参考价位 -->
    <view class="filter-group">
      <text class="filter-label">参考价位</text>
      <view class="filter-options">
        <view class="filter-chip-touch" bindtap="selectPriceLevel" data-value="">
          <view class="filter-chip {{priceNoLimitSelected ? 'chip-active' : ''}}">不限</view>
        </view>
        <view
          wx:for="{{priceLevels}}"
          wx:key="value"
          class="filter-chip-touch"
          bindtap="selectPriceLevel"
          data-value="{{item.value}}"
        >
          <view class="filter-chip {{item.selected ? 'chip-active' : ''}}">{{item.label}}</view>
        </view>
      </view>
      <text class="filter-hint">实际价格因门店、份量和用餐方式而异</text>
    </view>

    <!-- 口味 -->
    <view class="filter-group">
      <text class="filter-label">口味</text>
      <view class="filter-options">
        <view class="filter-chip-touch" bindtap="selectTaste" data-value="">
          <view class="filter-chip {{tasteNoLimitSelected ? 'chip-active' : ''}}">不限</view>
        </view>
        <view
          wx:for="{{tastes}}"
          wx:key="value"
          class="filter-chip-touch"
          bindtap="selectTaste"
          data-value="{{item.value}}"
        >
          <view class="filter-chip {{item.selected ? 'chip-active' : ''}}">{{item.label}}</view>
        </view>
      </view>
    </view>

    <!-- 食物类型（多选，与菜系合计最多3） -->
    <view class="filter-group">
      <text class="filter-label">食物类型（可选）</text>
      <view class="filter-options">
        <view class="filter-chip-touch" bindtap="selectCategoryNoLimit">
          <view class="filter-chip {{categoryNoLimitSelected ? 'chip-active' : ''}}">不限</view>
        </view>
        <view
          wx:for="{{typeTagOptions}}"
          wx:key="value"
          class="filter-chip-touch"
          bindtap="selectTypeTag"
          data-value="{{item.value}}"
        >
          <view class="filter-chip {{item.selected ? 'chip-active' : ''}}">{{item.label}}</view>
        </view>
      </view>
    </view>

    <!-- 菜系/风格（多选，与食物类型合计最多3） -->
    <view class="filter-group">
      <text class="filter-label">菜系/风格（可选）</text>
      <view class="filter-options">
        <view
          wx:for="{{cuisineTagOptions}}"
          wx:key="value"
          class="filter-chip-touch"
          bindtap="selectCuisineTag"
          data-value="{{item.value}}"
        >
          <view class="filter-chip {{item.selected ? 'chip-active' : ''}}">{{item.label}}</view>
        </view>
      </view>
    </view>

    <!-- 重置筛选 -->
    <view class="filter-reset-row">
      <text class="reset-link" bindtap="handleReset">重置筛选条件</text>
    </view>
  </view>

  <!-- 添加自定义菜入口 -->
  <view class="custom-food-entry" bindtap="goToCustomFood">
    <text>没找到想吃的？添加自定义菜 →</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading && !recommendResult && !mealDecision}}">
    <text>正在为你推荐...</text>
  </view>

  <!-- 错误状态 -->
  <view class="error-state" wx:if="{{errorMsg && !recommendResult && !mealDecision}}">
    <text>{{errorMsg}}</text>
    <button class="btn-secondary" bindtap="getRecommend" style="margin-top: 24rpx;">重试</button>
  </view>

  <!-- 已决定状态 -->
  <view class="result-area fade-up-in" wx:if="{{mealDecision}}">
    <view class="decision-block">
      <view class="decision-status">今天就吃</view>
      <view class="decision-food-name">
        {{mealDecision.foodName}}
        <text wx:if="{{mealDecision.source === 'CUSTOM'}}" class="custom-badge">自定义</text>
      </view>

      <!-- 类型/菜系标签 -->
      <view class="result-tags" wx:if="{{mealDecision.typeTags || mealDecision.cuisineTags}}">
        <text wx:for="{{tag.split(mealDecision.typeTags)}}" wx:key="*this" class="result-tag result-tag-type">{{item}}</text>
        <text wx:for="{{tag.split(mealDecision.cuisineTags)}}" wx:key="*this" class="result-tag result-tag-cuisine">{{item}}</text>
      </view>
      <view class="result-tags" wx:elif="{{mealDecision.category}}">
        <text class="result-tag result-tag-type">{{mealDecision.category}}</text>
      </view>

      <!-- 口味标签 -->
      <view class="result-tags" wx:if="{{mealDecision.tasteTags}}">
        <text wx:for="{{tag.split(mealDecision.tasteTags)}}" wx:key="*this" class="result-tag result-tag-taste">{{item}}</text>
      </view>

      <view class="decision-time">决定时间：{{decisionTimeDisplay}}</view>
    </view>
  </view>

  <!-- 推荐结果（无决定时） -->
  <view class="result-area fade-up-in" wx:elif="{{recommendResult}}">
    <view class="result-block">
      <view class="result-food-name">
        {{recommendResult.food.name}}
        <text wx:if="{{recommendResult.food.source === 'CUSTOM'}}" class="custom-badge">自定义</text>
      </view>

      <!-- 类型/菜系标签：拆分展示，与旧 category 互斥 -->
      <view class="result-tags" wx:if="{{recommendResult.food.typeTags || recommendResult.food.cuisineTags}}">
        <text wx:for="{{tag.split(recommendResult.food.typeTags)}}" wx:key="*this" class="result-tag result-tag-type">{{item}}</text>
        <text wx:for="{{tag.split(recommendResult.food.cuisineTags)}}" wx:key="*this" class="result-tag result-tag-cuisine">{{item}}</text>
      </view>
      <view class="result-tags" wx:elif="{{recommendResult.food.category}}">
        <text class="result-tag result-tag-type">{{recommendResult.food.category}}</text>
      </view>

      <!-- 口味标签：拆分展示，独立分组 -->
      <view class="result-tags result-tags-taste" wx:if="{{recommendResult.food.tasteTags}}">
        <text wx:for="{{tag.split(recommendResult.food.tasteTags)}}" wx:key="*this" class="result-tag result-tag-taste">{{item}}</text>
      </view>

      <view class="result-price">参考价位：{{priceDisplay}}</view>
      <view class="result-price-note">具体价格因门店、份量和用餐方式而异</view>

      <!-- 推荐理由：后端 reasons 数组逐条展示 -->
      <view class="result-reasons" wx:if="{{recommendResult.reasons.length > 0}}">
        <text class="result-reason-label">推荐理由</text>
        <text wx:for="{{recommendResult.reasons}}" wx:key="*this" class="result-reason-item">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 换一个已耗尽（2002）：独立空状态卡片 -->
  <view class="exhausted-card fade-up-in" wx:if="{{swapExhausted && !mealDecision}}">
    <text class="exhausted-title">当前条件没有更多合适菜品</text>
    <text class="exhausted-desc">可以放宽筛选条件或重新开始</text>
  </view>
</view>

<!-- 统一固定底部操作栏 -->
<view class="bottom-action-bar">
  <!-- 已决定 -->
  <block wx:if="{{mealDecision}}">
    <view class="action-buttons">
      <button class="btn-secondary action-btn action-btn-left" bindtap="handleReselect">重新选择</button>
      <button class="btn-primary action-btn action-btn-right" bindtap="handleFinishEating">吃完了，记录一下</button>
    </view>
  </block>

  <!-- 推荐结果 -->
  <block wx:elif="{{recommendResult}}">
    <view class="action-buttons">
      <button class="btn-secondary action-btn" bindtap="swapRecommend" disabled="{{swapCount >= maxSwapCount || loading}}">
        {{swapCount >= maxSwapCount ? '换不动了' : '换一个' + (swapCount > 0 ? '(' + swapCount + '/' + maxSwapCount + ')' : '')}}
      </button>
      <button class="btn-primary action-btn" bindtap="eatIt" disabled="{{loading}}">我就吃它</button>
    </view>
    <view class="dislike-action {{disliking ? 'dislike-disabled' : ''}}" bindtap="handleDislikeRecommendation">
      <text>{{disliking ? '处理中...' : '不喜欢这次推荐'}}</text>
    </view>
    <view class="blacklist-action" bindtap="addToBlacklist">
      <text>加入黑名单</text>
    </view>
  </block>

  <!-- 换一个已耗尽（2002）：卡片提示 + 双操作按钮 -->
  <block wx:elif="{{swapExhausted}}">
    <view class="action-buttons">
      <button class="btn-secondary action-btn" bindtap="resetSwapState">重置已看过</button>
      <button class="btn-primary action-btn" bindtap="handleReset">重置筛选条件</button>
    </view>
  </block>

  <!-- 未推荐 / 加载中 / 错误：单个主按钮 -->
  <block wx:else>
    <button class="btn-primary btn-single-action" bindtap="getRecommend" disabled="{{loading}}">
      {{loading ? '推荐中...' : '帮我选一个'}}
    </button>
  </block>
</view>
