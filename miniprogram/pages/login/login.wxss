/* pages/login/login.wxss */

.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.login-card {
  width: 90%;
  max-width: 600rpx;
  text-align: center;
  padding: 64rpx 48rpx;
}

.login-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.login-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.login-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 48rpx;
  line-height: 1.5;
}

.btn-login {
  width: 100%;
  height: 88rpx;
  font-size: 32rpx;
  margin-bottom: 24rpx;
}

.login-tip {
  font-size: 24rpx;
  color: #999;
}

.back-section {
  margin-top: 32rpx;
  text-align: center;
}

.back-link {
  font-size: 28rpx;
  color: #666;
  text-decoration: underline;
}
