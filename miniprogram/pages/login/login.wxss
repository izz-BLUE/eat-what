/* pages/login/login.wxss */

.login-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #FFF8EA;
}

/* 品牌视觉区 */
.login-hero {
  background-color: #FFB000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0 60rpx;
}

.login-hero-avatar {
  width: 220rpx;
  height: 220rpx;
  border-radius: 32rpx;
}

/* 内容区 */
.login-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 48rpx 48rpx;
  background-color: #FFF8EA;
}

.login-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #06452F;
  margin-bottom: 12rpx;
}

.login-desc {
  font-size: 28rpx;
  color: #7A7468;
  margin-bottom: 48rpx;
  line-height: 1.5;
  text-align: center;
}

.btn-login {
  width: 100%;
  max-width: 600rpx;
  min-height: 96rpx;
  font-size: 32rpx;
  margin-bottom: 20rpx;
}

.login-tip {
  font-size: 24rpx;
  color: #7A7468;
  margin-bottom: 40rpx;
}

.back-section {
  text-align: center;
}

.back-link {
  font-size: 26rpx;
  color: #7A7468;
}

/* 错误信息（在内容区内，不造成布局跳动） */
.login-error {
  text-align: center;
  padding: 16rpx 48rpx 32rpx;
  font-size: 26rpx;
  color: #D94A3A;
}
