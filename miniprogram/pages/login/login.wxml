<!--pages/login/login.wxml-->
<view class="login-page">
  <!-- 品牌视觉区 -->
  <view class="login-hero">
    <image class="login-hero-avatar brand-avatar-entrance" src="/assets/images/brand-avatar.png" mode="aspectFit" />
  </view>

  <!-- 内容区 -->
  <view class="login-body">
    <view class="login-title">今天吃啥</view>
    <view class="login-desc">登录后可以保存你的口味偏好和吃过记录</view>

    <button
      class="btn-primary btn-login"
      bindtap="handleLogin"
      disabled="{{loading}}"
    >
      {{loading ? '登录中...' : '微信登录'}}
    </button>

    <view class="login-tip">仅获取基本信息，不会获取你的手机号</view>

    <!-- 返回首页 -->
    <view class="back-section">
      <text class="back-link" bindtap="goBack">暂不登录，返回首页</text>
    </view>
  </view>

  <!-- 错误状态（在内容区内部，避免布局跳动） -->
  <view class="login-error" wx:if="{{errorMsg}}">
    <text>{{errorMsg}}</text>
  </view>
</view>
