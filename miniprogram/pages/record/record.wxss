/* pages/record/record.wxss */

.food-card {
  text-align: center;
  padding: 48rpx 32rpx;
}

.food-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.food-category {
  font-size: 28rpx;
  color: #FF6B35;
  background-color: #FFF3E8;
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.food-meal-type {
  font-size: 28rpx;
  color: #666;
  margin-top: 16rpx;
}

.loading-state {
  text-align: center;
  padding: 64rpx 0;
  color: #999;
}

.form-card {
  margin-top: 24rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
}

.form-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.form-option {
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  background-color: #f5f5f5;
  font-size: 26rpx;
  color: #666;
}

.form-option.active {
  background-color: #FF6B35;
  color: #fff;
}

.rating-section {
  display: flex;
  gap: 16rpx;
}

.star {
  font-size: 48rpx;
  color: #ddd;
  transition: color 0.2s;
}

.star.active {
  color: #FFD700;
}

.note-input {
  width: 100%;
  height: 200rpx;
  padding: 24rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.char-count {
  font-size: 24rpx;
  color: #999;
  text-align: right;
  display: block;
  margin-top: 8rpx;
}

.btn-submit {
  margin-top: 48rpx;
  width: 100%;
}

.success-state {
  text-align: center;
  padding: 64rpx 0;
}

.success-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.success-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 32rpx;
}
