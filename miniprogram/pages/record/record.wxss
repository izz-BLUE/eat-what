/* pages/record/record.wxss */

.record-page {
  min-height: 100vh;
  background-color: #FFF8EA;
  padding: 24rpx 32rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

/* 菜品信息头部 */
.record-food-header {
  display: flex;
  align-items: center;
  padding: 24rpx 0 28rpx;
}

.record-food-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.record-food-info {
  flex: 1;
  min-width: 0;
}

.record-food-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #19382D;
  display: block;
  word-break: break-all;
}

.record-food-meta {
  font-size: 26rpx;
  color: #7A7468;
  display: block;
  margin-top: 4rpx;
}

/* 评价表单 */
.record-form {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  border: 1rpx solid #E8DFD0;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #06452F;
  margin-bottom: 16rpx;
  display: block;
}

.form-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.form-option {
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  background-color: #F4EFE6;
  font-size: 26rpx;
  color: #19382D;
}

.form-option.active {
  background-color: #F24A0D;
  color: #fff;
}

/* 评分星星 */
.rating-section {
  display: flex;
  gap: 16rpx;
}

.star {
  font-size: 48rpx;
  color: #E8DFD0;
  transition: color 0.15s;
}

.star.star-active {
  color: #FFB000;
}

.star:active {
  transform: scale(0.97);
}

/* 备注输入框 */
.note-input {
  width: 100%;
  height: 200rpx;
  padding: 24rpx;
  border: 2rpx solid #E8DFD0;
  border-radius: 12rpx;
  font-size: 28rpx;
  background-color: #FFF8EA;
  box-sizing: border-box;
  transition: border-color 0.2s;
}

.note-input:focus {
  border-color: #06452F;
}

.char-count {
  font-size: 24rpx;
  color: #7A7468;
  text-align: right;
  display: block;
  margin-top: 8rpx;
}

/* 提交按钮 */
.btn-submit {
  width: 100%;
  margin-bottom: 16rpx;
}

/* 成功状态 */
.record-success {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 96rpx 32rpx;
}

.success-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.success-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #06452F;
  margin-bottom: 40rpx;
}

.btn-back {
  width: 320rpx;
}
