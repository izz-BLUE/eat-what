<!--pages/record/record.wxml-->
<view class="container">
  <!-- 加载详情中 -->
  <view class="loading-state" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <block wx:else>
    <!-- 提交前 -->
    <view wx:if="{{!submitted}}">
      <!-- 食物信息卡片（只读） -->
      <view class="card food-card">
        <view class="food-name">{{foodName}}</view>
        <view class="food-category" wx:if="{{category}}">{{category}}</view>
        <view class="food-meal-type">用餐：{{mealType || '未指定'}}</view>
      </view>

      <!-- 评价表单 -->
      <view class="card form-card">
        <!-- 评分 -->
        <view class="form-group">
          <text class="form-label">评分（选填）</text>
          <view class="rating-section">
            <view
              wx:for="{{5}}"
              wx:key="*this"
              class="star {{rating >= (index + 1) ? 'active' : ''}}"
              data-value="{{index + 1}}"
              bindtap="setRating"
            >
              ★
            </view>
          </view>
        </view>

        <!-- 备注 -->
        <view class="form-group">
          <text class="form-label">备注（选填）</text>
          <textarea
            class="note-input"
            value="{{note}}"
            placeholder="味道怎么样？"
            maxlength="256"
            bindinput="onNoteInput"
          />
          <text class="char-count">{{note.length}}/256</text>
        </view>
      </view>

      <!-- 提交按钮 -->
      <button
        class="btn-primary btn-submit"
        bindtap="submitRecord"
        disabled="{{submitting || submitted}}"
      >
        {{submitting ? '提交中...' : (status === 'DECIDED' ? '确认记录' : '保存评价')}}
      </button>

      <!-- 错误提示 -->
      <view class="error-state" wx:if="{{errorMsg && !submitted}}">
        <text>{{errorMsg}}</text>
      </view>
    </view>

    <!-- 提交后 -->
    <view class="success-state" wx:if="{{submitted}}">
      <view class="success-icon">✅</view>
      <view class="success-text">记录成功！</view>
      <button class="btn-primary" bindtap="goBack" style="margin-top:24rpx;">返回首页</button>
    </view>
  </block>
</view>
