<!--pages/record/record.wxml-->
<view class="record-page">
  <!-- 加载详情中 -->
  <view class="loading" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>

  <block wx:else>
    <!-- 提交前 -->
    <view wx:if="{{!submitted}}">
      <!-- 食物信息（只读） -->
      <view class="record-food-header">
        <image class="record-food-avatar brand-avatar-entrance" src="/assets/images/brand-avatar.png" mode="aspectFit" />
        <view class="record-food-info">
          <text class="record-food-name">{{foodName}}</text>
          <text class="record-food-meta">{{category}} · {{mealType || '未指定'}}</text>
        </view>
      </view>

      <!-- 评价表单 -->
      <view class="record-form">
        <!-- 评分 -->
        <view class="form-group">
          <text class="form-label">评分（选填）</text>
          <view class="rating-section">
            <view
              wx:for="{{5}}"
              wx:key="*this"
              class="star {{rating >= (index + 1) ? 'star-active' : ''}}"
              data-value="{{index + 1}}"
              bindtap="setRating"
            >
              ★
            </view>
          </view>
        </view>

        <!-- 备注 -->
        <view class="form-group">
          <text class="form-label">备注（选填）</text>
          <textarea
            class="note-input"
            value="{{note}}"
            placeholder="味道怎么样？"
            maxlength="256"
            bindinput="onNoteInput"
          />
          <text class="char-count">{{note.length}}/256</text>
        </view>
      </view>

      <!-- 提交按钮 -->
      <button
        class="btn-primary btn-submit"
        bindtap="submitRecord"
        disabled="{{submitting || submitted}}"
      >
        {{submitting ? '提交中...' : (status === 'DECIDED' ? '确认记录' : '保存评价')}}
      </button>

      <!-- 错误提示 -->
      <view class="error-state" wx:if="{{errorMsg && !submitted}}">
        <text>{{errorMsg}}</text>
      </view>
    </view>

    <!-- 提交成功 -->
    <view class="record-success" wx:if="{{submitted}}">
      <image class="success-avatar brand-avatar-entrance" src="/assets/images/brand-avatar.png" mode="aspectFit" />
      <view class="success-text">记录成功！</view>
      <button class="btn-primary btn-back" bindtap="goBack">返回首页</button>
    </view>
  </block>
</view>
