<!--pages/history/history.wxml-->
<view class="container">
  <view class="empty-state" wx:if="{{!loading && records.length === 0 && !errorMsg}}">
    <text>还没有吃过记录</text>
  </view>

  <view class="error-state" wx:elif="{{errorMsg}}">
    <text>{{errorMsg}}</text>
  </view>

  <block wx:else>
    <view class="record-item" wx:for="{{records}}" wx:key="id">
      <view class="record-header">
        <text class="record-name">{{item.foodName}}</text>
        <text class="record-meal">「{{item.mealType}}」</text>
        <view class="record-stars" wx:if="{{item.hasRating}}">
          <text wx:for="{{5}}" wx:for-item="s" wx:key="*this" class="star {{item.rating >= s ? 'active' : ''}}">★</text>
        </view>
      </view>
      <view class="record-note" wx:if="{{item.hasNote}}">{{item.note}}</view>
      <view class="record-time">{{item.eatenAt}}</view>
    </view>
  </block>
</view>
