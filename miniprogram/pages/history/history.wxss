/* pages/history/history.wxss */

.record-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.record-header {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.record-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.record-meal {
  font-size: 26rpx;
  color: #FF6B35;
  background: #FFF3E8;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.record-stars {
  margin-left: auto;
}

.star {
  font-size: 28rpx;
  color: #ddd;
}

.star.active {
  color: #FFD700;
}

.record-note {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
  word-break: break-all;
}

.record-time {
  font-size: 24rpx;
  color: #999;
}

/* 状态徽章 */
.status-badge {
  display: inline-block;
  font-size: 22rpx;
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
  margin-bottom: 8rpx;
}

.status-badge.decided {
  color: #4CAF50;
  background-color: #E8F5E9;
}

.status-badge.eaten {
  color: #999;
  background-color: #f5f5f5;
}

/* 操作按钮区 */
.record-actions {
  margin-top: 16rpx;
  display: flex;
  gap: 16rpx;
}

.btn-small {
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 8rpx;
  border: none;
}
