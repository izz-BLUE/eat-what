<!--pages/profile/profile.wxml-->
<view class="container">
  <view class="card profile-card">
    <view class="profile-avatar">🍽️</view>
    <view class="profile-nickname">{{nickname}}</view>
    <view class="profile-status">{{isLoggedIn ? '已登录' : '未登录'}}</view>

    <button class="btn-primary btn-login" wx:if="{{!isLoggedIn}}" bindtap="goToLogin">微信登录</button>
    <button class="btn-secondary btn-logout" wx:if="{{isLoggedIn}}" bindtap="handleLogout">退出登录</button>
  </view>

  <view class="menu-section" wx:if="{{isLoggedIn}}">
    <view class="menu-item" bindtap="goToHistory">
      <text class="menu-icon">📋</text>
      <text class="menu-text">吃过记录</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToBlacklist">
      <text class="menu-icon">🚫</text>
      <text class="menu-text">黑名单</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToDislike">
      <text class="menu-icon">⏸</text>
      <text class="menu-text">暂时不想吃</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
